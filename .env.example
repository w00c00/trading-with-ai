APP_NAME=Trading with AI
HOST=0.0.0.0
PORT=3471

# Trading safety
LIVE_TRADING_ENABLED=false
DEFAULT_EXCHANGE=paper
DEFAULT_SYMBOL=BTC/USDT
DEFAULT_TIMEFRAME=1h
TRADE_QUOTE_SIZE=50
MAX_POSITION_QUOTE=200
MIN_AI_CONFIDENCE=0.55

# Exchange credentials. For paper trading these are not needed.
EXCHANGE_ID=binance
EXCHANGE_API_KEY=
EXCHANGE_SECRET=
EXCHANGE_PASSWORD=
EXCHANGE_SANDBOX=true

# AI provider: openrouter, openai, minimax, mimo, or custom_openai_compatible
AI_PROVIDER=openrouter
AI_MODEL=openai/gpt-4o-mini
AI_API_KEY=
AI_BASE_URL=

# Provider defaults if AI_BASE_URL is empty:
# openrouter -> https://openrouter.ai/api/v1
# openai     -> https://api.openai.com/v1
# minimax    -> https://api.minimaxi.com/v1
# mimo       -> https://api.mimo-v2.com/v1

# 方糖 Server酱推送。填入自己的 SendKey 后，成交成功会推送成本、利润、成交详情。
SERVERCHAN_SENDKEY=
NOTIFY_TRADE_SUCCESS=true
NOTIFY_DRY_RUN=false
